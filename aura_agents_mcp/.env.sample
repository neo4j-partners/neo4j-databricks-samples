# Neo4j Aura Agent MCP — Configuration
# Copy to .env and fill in values:  cp .env.sample .env

# MCP server endpoint URL (quote the value — the URL contains & characters)
# From Aura Console -> Agents -> ... -> Copy MCP server endpoint
# Example: MCP_SERVER_URL="https://mcp.neo4j.io/agent?project_id=abc123&agent_id=def456"
MCP_SERVER_URL=""

# OAuth client credentials (generated by discover-oauth.py)
# Run: uv run discover-oauth.py
# Then paste the printed values here.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Redirect URI for the OAuth callback (default works for local testing)
OAUTH_REDIRECT_URI=http://localhost:8400/callback
