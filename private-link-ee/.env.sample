# Neo4j EE Private Link Configuration
# Copy to .env and fill in values:  cp .env.sample .env

# Azure resource group containing the Neo4j marketplace deployment
RESOURCE_GROUP=

# Discovered from the marketplace deployment (set by --init)
VMSS_NAME=
VNET_NAME=
NEO4J_SUBNET_NAME=
NEO4J_URI=

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Private Link configuration
PLS_SUBNET_PREFIX=10.1.0.0/24

# Databricks NCC (used in setup script output instructions)
DATABRICKS_ACCOUNT_ID=
NCC_ID=
NEO4J_DOMAIN=neo4j-ee.internal.yourdomain.com
