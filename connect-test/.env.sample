# Neo4j Connection Credentials
# These are loaded into Databricks secrets by setup.sh

# Neo4j host (without protocol prefix)
# e.g., for "neo4j+s://example.databases.neo4j.io" use "example.databases.neo4j.io"
NEO4J_HOST=your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# Optional: database name (defaults to "neo4j")
NEO4J_DATABASE=neo4j
